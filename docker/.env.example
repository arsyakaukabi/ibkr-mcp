# Copy this file to docker/.env and fill in your IBKR credentials.
# docker/.env is git-ignored — never commit it.

# IBKR account credentials. Paper-account credentials are different from your
# live account; you can find them at https://www.interactivebrokers.com/sso/Login
# under "Settings → Paper Trading Account".
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password

# Trading mode: "paper" (default) or "live".
# Must match the adapter's IBKR_TRADING_MODE env var, and dictates which
# port the Gateway listens on inside the container: paper→4002, live→4001.
TRADING_MODE=paper

# Optional: restrict the Gateway to read-only API operations. Set to "yes" if
# you want the API to refuse order placement and only allow reads/quotes.
# Defaults to "no" so the adapter's preview/place flow works.
READ_ONLY_API=no

# Optional: time zone for the Gateway. Defaults to UTC.
TIME_ZONE=Etc/UTC

# Optional: VNC password for debugging the Gateway GUI on 127.0.0.1:5900.
# Leave blank to disable VNC password (still localhost-only so no network risk).
VNC_SERVER_PASSWORD=
